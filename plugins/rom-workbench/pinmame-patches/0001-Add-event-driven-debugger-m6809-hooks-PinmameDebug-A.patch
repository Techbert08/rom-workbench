+/******************************************************
+ * Debugger: event-driven breakpoints, watchpoints, step
+ *
+ * The m6809 dispatch loop calls pinmame_dbg_check_pc(PCD) before each
+ * instruction. The memory subsystem calls pinmame_dbg_check_mem(addr,
+ * is_write, value) on each access. When a condition fires, the emulation
+ * thread captures registers into g_dbgEvent, signals g_dbgFiredCv, then
+ * blocks on g_dbgResumeCv until the host calls Continue or Step.
+ *
+ * The host thread (e.g. Python) calls PinmameDebugWait, which waits on
+ * g_dbgFiredCv. It then reads regs/memory at leisure and calls Continue
+ * or Step to release the emulation thread.
+ *
+ * Watchpoints are kept in a std::map<addr, flags>; lookups use a hashed
+ * fast-path bitmap (m6809 has a 16-bit address space, 8 KB suffices). The
+ * bitmap is cheap to test in the hot path and the map provides the
+ * read/write flag distinction.
+ ******************************************************/
+
+namespace {
+	std::mutex                  g_dbgMutex;
+	std::condition_variable     g_dbgFiredCv;
+	std::condition_variable     g_dbgResumeCv;
+	bool                        g_dbgAttached    = false;
+	bool                        g_dbgFiredFlag   = false;
+	bool                        g_dbgResumeFlag  = false;
+	bool                        g_dbgStepPending = false;
+	PinmameDebugEvent           g_dbgEvent {};
+	std::set<uint32_t>          g_dbgBreakpoints;
+	/* watchpoint flag bits */
+	enum { WP_READ = 1, WP_WRITE = 2 };
+	std::map<uint32_t, uint8_t> g_dbgWatchpoints;
+
+	/* Fast-path bitmaps for the m6809 64KB address space. One bit per
+	 * 16-bit address: 65536 / 8 = 8192 bytes. The hot path in the CPU
+	 * dispatch loop only reads these arrays; mutation happens under the
+	 * mutex from API setters. */
+	constexpr size_t WP_BITMAP_BYTES = 8192;
+	uint8_t g_dbgWpReadBitmap [WP_BITMAP_BYTES] = {0};
+	uint8_t g_dbgWpWriteBitmap[WP_BITMAP_BYTES] = {0};
+	/* Same idea for breakpoints, drops the set lookup from the hot path */
+	uint8_t g_dbgBpBitmap[WP_BITMAP_BYTES] = {0};
+
+	static inline void bitmap_set(uint8_t* bm, uint32_t addr, bool on) {
+		uint32_t a = addr & 0xFFFFu;
+		uint8_t mask = static_cast<uint8_t>(1u << (a & 7));
+		if (on) bm[a >> 3] |=  mask;
+		else    bm[a >> 3] &= ~mask;
+	}
+	static inline bool bitmap_get(const uint8_t* bm, uint32_t addr) {
+		uint32_t a = addr & 0xFFFFu;
+		return (bm[a >> 3] >> (a & 7)) & 1u;
+	}
+
+	/* Populate the regs portion of g_dbgEvent. Called with mutex held. */
+	void dbg_fill_regs(PinmameMainCPURegs* p) {
+		p->pc = static_cast<uint16_t>(cpunum_get_reg(0, M6809_PC));
+		p->s  = static_cast<uint16_t>(cpunum_get_reg(0, M6809_S));
+		p->u  = static_cast<uint16_t>(cpunum_get_reg(0, M6809_U));
+		p->x  = static_cast<uint16_t>(cpunum_get_reg(0, M6809_X));
+		p->y  = static_cast<uint16_t>(cpunum_get_reg(0, M6809_Y));
+		p->a  = static_cast<uint8_t>(cpunum_get_reg(0, M6809_A) & 0xFF);
+		p->b  = static_cast<uint8_t>(cpunum_get_reg(0, M6809_B) & 0xFF);
+		p->cc = static_cast<uint8_t>(cpunum_get_reg(0, M6809_CC) & 0xFF);
+		p->dp = static_cast<uint8_t>(cpunum_get_reg(0, M6809_DP) & 0xFF);
+	}
+
+	/* Common break path: fire event to host, then block until resumed.
+	 * Caller passes reason and any watchpoint fields; we fill regs. */
+	void dbg_fire_and_wait(uint32_t reason, uint32_t watch_addr,
+	                       uint8_t is_write, uint8_t value) {
+		std::unique_lock<std::mutex> lk(g_dbgMutex);
+		if (!g_dbgAttached) return;
+		PinmameDebugEvent ev {};
+		ev.reason         = reason;
+		ev.watch_addr     = watch_addr;
+		ev.watch_is_write = is_write;
+		ev.watch_value    = value;
+		dbg_fill_regs(&ev.regs);
+		ev.hit_pc = ev.regs.pc;
+		g_dbgEvent       = ev;
+		g_dbgFiredFlag   = true;
+		g_dbgStepPending = false;
+		g_dbgFiredCv.notify_all();
+		g_dbgResumeCv.wait(lk, []{ return g_dbgResumeFlag || !g_dbgAttached; });
+		g_dbgResumeFlag = false;
+	}
+} /* namespace */
+
+/* Hot-path predicates called from m6809.c. Inline-safe: just bitmap reads
+ * plus an attached/step flag check. No locking — these are advisory; the
+ * heavy work happens inside dbg_fire_and_wait, which acquires the mutex. */
+extern "C" int pinmame_dbg_check_pc(unsigned int pc) {
+	if (!g_dbgAttached) return 0;
+	if (g_dbgStepPending) {
+		dbg_fire_and_wait(PINMAME_DBG_REASON_STEP, 0, 0, 0);
+		return 1;
+	}
+	if (bitmap_get(g_dbgBpBitmap, pc)) {
+		dbg_fire_and_wait(PINMAME_DBG_REASON_BREAKPOINT, 0, 0, 0);
+		return 1;
+	}
+	return 0;
+}
+
+extern "C" int pinmame_dbg_check_mem(unsigned int addr, int is_write,
+                                     unsigned int value) {
+	if (!g_dbgAttached) return 0;
+	const uint8_t* bm = is_write ? g_dbgWpWriteBitmap : g_dbgWpReadBitmap;
+	if (!bitmap_get(bm, addr)) return 0;
+	dbg_fire_and_wait(PINMAME_DBG_REASON_WATCHPOINT, addr,
+	                  static_cast<uint8_t>(is_write ? 1 : 0),
+	                  static_cast<uint8_t>(value & 0xFFu));
+	return 1;
+}
+
+PINMAMEAPI void PinmameDebugAttach(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgAttached    = true;
+	g_dbgFiredFlag   = false;
+	g_dbgResumeFlag  = false;
+	g_dbgStepPending = false;
+}
+
+PINMAMEAPI void PinmameDebugDetach(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgAttached    = false;
+	g_dbgStepPending = false;
+	g_dbgBreakpoints.clear();
+	g_dbgWatchpoints.clear();
+	std::fill(std::begin(g_dbgBpBitmap),      std::end(g_dbgBpBitmap),      0);
+	std::fill(std::begin(g_dbgWpReadBitmap),  std::end(g_dbgWpReadBitmap),  0);
+	std::fill(std::begin(g_dbgWpWriteBitmap), std::end(g_dbgWpWriteBitmap), 0);
+	/* Unblock any in-flight emulation break and any pending Wait. */
+	g_dbgResumeFlag = true;
+	g_dbgFiredFlag  = true;
+	g_dbgEvent      = {};
+	g_dbgEvent.reason = PINMAME_DBG_REASON_DETACHED;
+	g_dbgResumeCv.notify_all();
+	g_dbgFiredCv.notify_all();
+}
+
+PINMAMEAPI int PinmameDebugIsAttached(void) {
+	return g_dbgAttached ? 1 : 0;
+}
+
+PINMAMEAPI void PinmameDebugAddBreakpoint(uint32_t pc) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgBreakpoints.insert(pc & 0xFFFFu);
+	bitmap_set(g_dbgBpBitmap, pc, true);
+}
+
+PINMAMEAPI void PinmameDebugRemoveBreakpoint(uint32_t pc) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgBreakpoints.erase(pc & 0xFFFFu);
+	bitmap_set(g_dbgBpBitmap, pc, false);
+}
+
+PINMAMEAPI void PinmameDebugClearBreakpoints(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgBreakpoints.clear();
+	std::fill(std::begin(g_dbgBpBitmap), std::end(g_dbgBpBitmap), 0);
+}
+
+PINMAMEAPI void PinmameDebugAddWatchpoint(uint32_t addr, int on_read, int on_write) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	uint8_t flags = 0;
+	if (on_read)  flags |= WP_READ;
+	if (on_write) flags |= WP_WRITE;
+	if (!flags) {
+		g_dbgWatchpoints.erase(addr & 0xFFFFu);
+		bitmap_set(g_dbgWpReadBitmap,  addr, false);
+		bitmap_set(g_dbgWpWriteBitmap, addr, false);
+		return;
+	}
+	g_dbgWatchpoints[addr & 0xFFFFu] = flags;
+	bitmap_set(g_dbgWpReadBitmap,  addr, (flags & WP_READ)  != 0);
+	bitmap_set(g_dbgWpWriteBitmap, addr, (flags & WP_WRITE) != 0);
+}
+
+PINMAMEAPI void PinmameDebugRemoveWatchpoint(uint32_t addr) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgWatchpoints.erase(addr & 0xFFFFu);
+	bitmap_set(g_dbgWpReadBitmap,  addr, false);
+	bitmap_set(g_dbgWpWriteBitmap, addr, false);
+}
+
+PINMAMEAPI void PinmameDebugClearWatchpoints(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgWatchpoints.clear();
+	std::fill(std::begin(g_dbgWpReadBitmap),  std::end(g_dbgWpReadBitmap),  0);
+	std::fill(std::begin(g_dbgWpWriteBitmap), std::end(g_dbgWpWriteBitmap), 0);
+}
+
+PINMAMEAPI int PinmameDebugWait(uint32_t timeout_ms,
+                                PinmameDebugEvent* const p_event) {
+	if (p_event == nullptr) return 0;
+	std::unique_lock<std::mutex> lk(g_dbgMutex);
+	auto cond = []{ return g_dbgFiredFlag; };
+	bool ok;
+	if (timeout_ms == 0) {
+		g_dbgFiredCv.wait(lk, cond);
+		ok = true;
+	} else {
+		ok = g_dbgFiredCv.wait_for(lk, std::chrono::milliseconds(timeout_ms), cond);
+	}
+	if (!ok) return 0;
+	*p_event = g_dbgEvent;
+	g_dbgFiredFlag = false;
+	return 1;
+}
+
+PINMAMEAPI void PinmameDebugContinue(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgStepPending = false;
+	g_dbgResumeFlag  = true;
+	g_dbgResumeCv.notify_all();
+}
+
+PINMAMEAPI void PinmameDebugStep(void) {
+	std::lock_guard<std::mutex> lk(g_dbgMutex);
+	g_dbgStepPending = true;
+	g_dbgResumeFlag  = true;
+	g_dbgResumeCv.notify_all();
+}
+
