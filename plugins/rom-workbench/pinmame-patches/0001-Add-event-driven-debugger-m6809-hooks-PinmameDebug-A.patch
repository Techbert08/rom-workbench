+ * Event-driven breakpoint/watchpoint/step facility for the main CPU. The
+ * emulation thread blocks the moment a break condition fires; Python (or
+ * any host) wakes up via PinmameDebugWait, inspects state, then resumes
+ * the emulation via PinmameDebugContinue or PinmameDebugStep.
+ *
+ * Lifecycle:
+ *   1. PinmameDebugAttach()         -- enables the hook
+ *   2. PinmameDebugAddBreakpoint(pc) -- (and/or watchpoints)
+ *   3. PinmameDebugWait(...)         -- blocks; emulation runs free
+ *   4. (event arrives) inspect regs / memory
+ *   5. PinmameDebugContinue() or PinmameDebugStep()
+ *   6. loop back to (3) until done
+ *   7. PinmameDebugDetach()         -- removes the hook and unblocks any
+ *                                       in-flight emulation break
+ *
+ * Thread safety: PinmameDebugWait is intended for a host thread different
+ * from the emulation thread (typical libpinmame use: Python main thread
+ * waits, libpinmame's game-thread emulates). Continue/Step may be called
+ * from any thread; they only signal a condition variable. -------------- */
+
+typedef enum {
+	PINMAME_DBG_REASON_NONE       = 0,
+	PINMAME_DBG_REASON_BREAKPOINT = 1,
+	PINMAME_DBG_REASON_WATCHPOINT = 2,
+	PINMAME_DBG_REASON_STEP       = 3,
+	PINMAME_DBG_REASON_DETACHED   = 4
+} PINMAME_DBG_REASON;
+
+typedef struct {
+	uint32_t reason;          /* PINMAME_DBG_REASON */
+	PinmameMainCPURegs regs;  /* snapshot at the moment of break */
+	uint32_t hit_pc;          /* PC at break (same as regs.pc, for clarity) */
+	uint32_t watch_addr;      /* watchpoint hit address (else 0) */
+	uint8_t  watch_is_write;  /* 1 if write triggered, 0 if read */
+	uint8_t  watch_value;     /* byte value at the access (post-write/pre-read) */
+	uint8_t  _pad[2];
+} PinmameDebugEvent;
+
+PINMAMEAPI void PinmameDebugAttach(void);
+PINMAMEAPI void PinmameDebugDetach(void);
+PINMAMEAPI int  PinmameDebugIsAttached(void);
+
+PINMAMEAPI void PinmameDebugAddBreakpoint(uint32_t pc);
+PINMAMEAPI void PinmameDebugRemoveBreakpoint(uint32_t pc);
+PINMAMEAPI void PinmameDebugClearBreakpoints(void);
+
+/* Watchpoints fire on memory accesses to the given 16-bit CPU address.
+ * on_read / on_write are independent flags; pass 0/1. */
+PINMAMEAPI void PinmameDebugAddWatchpoint(uint32_t addr, int on_read, int on_write);
+PINMAMEAPI void PinmameDebugRemoveWatchpoint(uint32_t addr);
+PINMAMEAPI void PinmameDebugClearWatchpoints(void);
+
+/* Block until a debug event fires or timeout_ms expires.
+ * timeout_ms == 0 means wait forever.
+ * Returns 1 if p_event was filled, 0 on timeout. */
+PINMAMEAPI int PinmameDebugWait(uint32_t timeout_ms, PinmameDebugEvent* const p_event);
+
+/* Resume execution. Continue runs until the next bp/wp; Step executes one
+ * instruction then breaks again (with reason=PINMAME_DBG_REASON_STEP). */
+PINMAMEAPI void PinmameDebugContinue(void);
+PINMAMEAPI void PinmameDebugStep(void);
 PINMAMEAPI const uint8_t* PinmameGetRawMemoryRegion(const int region);
 PINMAMEAPI size_t PinmameGetRawMemoryRegionLength(const int region);
 PINMAMEAPI void PinmameSetUserData(void* const p_userData);
