{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/zachc/congo/record-pinball/session.schema.json",
    "title": "record-pinball session.jsonl record",
    "description": "Newline-delimited JSON records emitted by record.ps1. The first record MUST be of kind 'meta'. All other records are timestamped events. Time `t` is seconds since PinmameRun returned (or, in InpOnly mode, seconds since recording started).",
    "oneOf": [
        {
            "type": "object",
            "required": ["v", "kind", "rom", "mode", "start_ts"],
            "properties": {
                "v": { "const": 1 },
                "kind": { "const": "meta" },
                "rom": { "type": "string", "description": "VPM rom name (the folder under VPM/roms/)" },
                "rom_zip_sha256": { "type": ["string", "null"] },
                "table_path": { "type": ["string", "null"] },
                "table_sha256": { "type": ["string", "null"] },
                "vpm_version": { "type": ["string", "null"] },
                "pinmame_version": { "type": ["string", "null"] },
                "mode": { "enum": ["VpVpm", "InpOnly"] },
                "poll_hz": { "type": "integer", "minimum": 1 },
                "start_ts": { "type": "string", "format": "date-time" },
                "end_ts": { "type": ["string", "null"], "format": "date-time" },
                "sample_loss_count": { "type": "integer", "minimum": 0 },
                "host": { "type": "string" },
                "comment": { "type": ["string", "null"] }
            },
            "additionalProperties": false
        },
        {
            "type": "object",
            "required": ["t", "kind", "n", "on"],
            "description": "Switch state change. Replay uses these as inputs.",
            "properties": {
                "t": { "type": "number", "minimum": 0 },
                "kind": { "const": "switch" },
                "n": { "type": "integer", "minimum": 1, "maximum": 256 },
                "on": { "type": "boolean" }
            },
            "additionalProperties": false
        },
        {
            "type": "object",
            "required": ["t", "kind", "n", "on"],
            "description": "Solenoid event observation (from VPM OnSolenoid). Output-side; used as a diff baseline.",
            "properties": {
                "t": { "type": "number", "minimum": 0 },
                "kind": { "const": "solenoid_evt" },
                "n": { "type": "integer", "minimum": 1, "maximum": 256 },
                "on": { "type": "boolean" }
            },
            "additionalProperties": false
        },
        {
            "type": "object",
            "required": ["t", "kind", "n", "v"],
            "description": "Lamp / solenoid / GI string observation polled from VPM. Output-side; used as a diff baseline.",
            "properties": {
                "t": { "type": "number", "minimum": 0 },
                "kind": { "enum": ["lamp", "sol", "gi"] },
                "n": { "type": "integer", "minimum": 0 },
                "v": { "type": "integer" }
            },
            "additionalProperties": false
        },
        {
            "type": "object",
            "required": ["t", "kind", "msg"],
            "description": "Free-form annotation (e.g. user-pressed marker during recording, or internal note).",
            "properties": {
                "t": { "type": "number", "minimum": 0 },
                "kind": { "const": "note" },
                "msg": { "type": "string" }
            },
            "additionalProperties": false
        }
    ]
}
